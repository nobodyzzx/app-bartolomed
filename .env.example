# ═══════════════════════════════════════════════════════════════
# BARTOLOMÉ APP — Variables de entorno para producción (Dokploy)
# Copia este archivo como referencia al configurar las env vars
# en el panel de Dokploy. NUNCA subas un .env con valores reales.
# ═══════════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ────────────────────────────────────
POSTGRES_DB=bartolomed
POSTGRES_USER=med_user
POSTGRES_PASSWORD=cambia_por_password_seguro

# ── JWT (usar strings hexadecimales de 128 chars) ───────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_por_string_hex_128_chars
JWT_REFRESH_SECRET=cambia_por_string_hex_128_chars_diferente

# ── Bootstrap SUPER_ADMIN (usado una sola vez, ver GODMODE-SETUP.md) ──
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOD_MODE_TOKEN=cambia_por_token_secreto

# ── Dominio público del frontend ────────────────────────────────
FRONTEND_DOMAIN=bartolomed.tecnocondor.dev

# ── Traefik (valores por defecto de Dokploy, ajustar si difieren) ──
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_NETWORK=dokploy-network
