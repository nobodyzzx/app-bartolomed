  getProducts(): Observable<MedicationStock[]> {
    return of(this.stock)
  }

  getProduct(id: string): Observable<MedicationStock | undefined> {
    const product = this.stock.find(p => p.id === id)
    return of(product)
  }

  addProduct(product: MedicationStock): Observable<MedicationStock> {
    const newProduct = { ...product, id: this.generateId() }
    this.stock.push(newProduct)
    return of(newProduct)
  }

  updateProduct(id: string, product: Partial<MedicationStock>): Observable<MedicationStock | null> {
    const index = this.stock.findIndex(p => p.id === id)
    if (index > -1) {
      this.stock[index] = { ...this.stock[index], ...product }
      return of(this.stock[index])
    }
    return of(null)
  }

  deleteProduct(id: string): Observable<boolean> {
    const index = this.stock.findIndex(p => p.id === id)
    if (index > -1) {
      this.stock.splice(index, 1)
      return of(true)
    }
    return of(false)
  }

  getLowStockProducts(): Observable<MedicationStock[]> {
    const lowStock = this.stock.filter(p => p.quantity <= (p.minimumStock || 0))
    return of(lowStock)
  }

  getExpiringProducts(): Observable<MedicationStock[]> {
    const today = new Date()
    const thirtyDaysFromNow = new Date(today.getTime() + 30 * 24 * 60 * 60 * 1000)

    const expiring = this.stock.filter(p => {
      const expirationDate = new Date(p.expiryDate)
      return expirationDate <= thirtyDaysFromNow
    })

    return of(expiring)
  }

  private generateId(): string {
    const maxNum = this.stock
      .map(p => parseInt(p.id.split('-')[1] || '0'))
      .reduce((max, num) => Math.max(max, num), 0)
    return `stock-${String(maxNum + 1).padStart(3, '0')}`
  }
}
